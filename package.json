{
  "name": "decentralized-digital-will-protocol",
  "version": "1.0.0",
  "description": "A decentralized, non-custodial system that encrypts your digital life and automatically releases only what you choose, only to whom you choose, only when you are no longer active.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:core": "cd core && tsc",
    "dev": "ts-node demo.ts",
    "demo": "ts-node demo.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint **/*.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "rm -rf dist node_modules",
    "setup": "npm install && cd frontend/web && npm install && cd ../mobile && npm install",
    "start": "bash ./start.sh",
    "start:services": "bash ./start.sh",
    "start:web": "cd frontend/web && npm run dev",
    "start:mobile": "cd frontend/mobile && npm start"
  },
  "keywords": [
    "blockchain",
    "digital-will",
    "inheritance",
    "smart-contracts",
    "cryptography",
    "decentralized",
    "dead-man-switch",
    "shamir-secret-sharing",
    "ipfs",
    "arweave",
    "ethereum",
    "polygon"
  ],
  "author": "Digital Will Protocol Team",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.0",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/jest": "^29.5.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.8.0",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "chai": "^4.3.10",
    "dotenv": "^17.3.1",
    "eslint": "^8.52.0",
    "ethers": "^6.16.0",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^1.0.10",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "solidity-coverage": "^0.8.17",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typechain": "^8.3.2",
    "typescript": "^5.2.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "expo": "^55.0.6",
    "fast-check": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
