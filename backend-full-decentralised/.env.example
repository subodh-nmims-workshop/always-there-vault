# ========================================
# Blockchain Configuration (Mumbai Testnet - FREE)
# ========================================

# Your wallet private key (NEVER commit this!)
# Get test MATIC from: https://faucet.polygon.technology
PRIVATE_KEY=your_wallet_private_key_here

# RPC URLs (FREE public RPCs)
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com
POLYGON_RPC_URL=https://polygon-rpc.com

# PolygonScan API Key (optional, for contract verification)
# Get from: https://polygonscan.com/apis
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# ========================================
# IPFS Configuration (web3.storage - FREE 5GB)
# ========================================

# Get your token from: https://web3.storage
WEB3_STORAGE_TOKEN=your_web3_storage_token_here

# ========================================
# Network Configuration
# ========================================

# Network (testnet or mainnet)
NETWORK=testnet

# ========================================
# Deployed Contract Addresses
# ========================================
# (Fill these after deployment)

HEARTBEAT_TRACKER_ADDRESS=
DIGITAL_WILL_ADDRESS=
ASSET_MANAGER_ADDRESS=
