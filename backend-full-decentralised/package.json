{
  "name": "backend-full-decentralised",
  "version": "1.0.0",
  "description": "Fully decentralized backend - No server needed!",
  "scripts": {
    "setup": "chmod +x scripts/setup.sh && ./scripts/setup.sh",
    "compile": "hardhat compile",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network mumbai",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network polygon",
    "deploy:local": "hardhat run scripts/deploy.ts --network hardhat",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "verify": "hardhat verify --network mumbai",
    "clean": "hardhat clean",
    "node": "hardhat node"
  },
  "dependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.6.1",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "hardhat": "^2.19.0",
    "web3.storage": "^4.5.5"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "chai": "^4.3.10",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.1",
    "typechain": "^8.3.0",
    "typescript": "^5.3.0"
  }
}
