# ========================================
# DeadMan Protocol - Root Environment Variables
# Copy this to .env and update with your values
# ========================================

# App
NODE_ENV=production
FRONTEND_URL=https://app.yourdomain.com
BACKEND_URL=https://api.yourdomain.com

# Databases
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lastwish
MONGODB_URI=mongodb://admin:password@localhost:27017/digital-will?authSource=admin

# JWT Security
JWT_SECRET=your_super_secret_jwt_key_min_32_characters

# Stripe (Payments)
# Get from https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Email (Notifications)
# Get from https://resend.com or use Gmail App Password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-digit-app-password
SMTP_FROM="Last Wish Protocol" <your-email@gmail.com>

# IPFS Storage
PINATA_API_KEY=your_key
PINATA_SECRET_API_KEY=your_secret

# Blockchain (Digital Will Smart Contract)
# Get RPC from https://www.alchemy.com/
CONTRACT_ADDRESS=0x...
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your-key
ADMIN_PRIVATE_KEY=0x... (Private Key for automated triggers)
NETWORK_NAME=polygon-mainnet

# Monitoring/Error Tracking
SENTRY_DSN=https://...
GRAFANA_PASSWORD=admin
