# ========================================
# DeadMan Protocol - Backend Configuration
# ========================================

# Server
NODE_ENV=development
PORT=7001
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRATION=7d

# Database
# Local SQLite/Drizzle path (optional if using Postgres)
DATABASE_PATH=digital-will.db
# MongoDB (legacy/analytics)
MONGODB_URI=mongodb://admin:password@127.0.0.1:27017/digital-will?authSource=admin
# Postgres (Drizzle)
DATABASE_URL=postgres://postgres:password@localhost:5432/digital-will

# Blockchain (Hardhat/Local)
ETHEREUM_RPC_URL=http://127.0.0.1:8545
CONTRACT_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
KEEPER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Heartbeat Configuration
HEARTBEAT_CHECK_INTERVAL="0 */6 * * *"
HEARTBEAT_GRACE_PERIOD_DAYS=30

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:8081
FRONTEND_URL=http://localhost:3000
MOBILE_URL=exp://localhost:19000

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email Service (Notification/Recovery)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=test@example.com
SMTP_PASS=test
SMTP_FROM="DeadMan Protocol" <noreply@deadmanprotocol.com>

# IPFS (Decentralized Storage)
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET=your_pinata_secret
WEB3_STORAGE_TOKEN=your_web3_storage_token_optional

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# Logging
LOG_LEVEL=info

# ========================================
# ADVANCED SECURITY & ENCRYPTION
# ========================================

# Store master key in AWS KMS or HashiCorp Vault
# CiphertextBlob in base64 format from KMS decrypt
ENCRYPTION_MASTER_KEY_CIPHER=aws:kms:arn:aws:kms:us-east-1:123456789:key/abc-123
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=yyy

# Local development fallback (32 bytes hex)
ENCRYPTION_MASTER_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f

# Key rotation versioning
ENCRYPTION_KEY_VERSION=2

# Security Scanning & Compliance
SECURITY_SCAN_SYNK_TOKEN=your-token
SECURITY_SCAN_THRESHOLD=high

# 2FA / MFA Settings
MFA_ISSUER=DeadMan Protocol
MFA_WINDOW=1
RECOVERY_CODES_COUNT=10
