# ========================================
# DeadMan Protocol - Backend Configuration
# ========================================

# Server
NODE_ENV=development
PORT=7001

# Database
MONGODB_URI=mongodb://admin:password@127.0.0.1:27017/digital-will?authSource=admin

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d

# Stripe Payment (Get from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Email Service (Get from https://resend.com)
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=noreply@deadmanprotocol.com

# Error Tracking (Optional - Get from https://sentry.io)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Blockchain (Hardhat)
HARDHAT_NETWORK=localhost
HARDHAT_RPC_URL=http://localhost:8545

# IPFS (Optional)
IPFS_GATEWAY=https://ipfs.io/ipfs/
WEB3_STORAGE_TOKEN=your_web3_storage_token_here

# CORS
CORS_ORIGIN=http://localhost:7000,http://localhost:3000

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# Cache
CACHE_TTL=300000

# Logging
LOG_LEVEL=info
